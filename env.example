# ── Client-side (Vite exposes these to the browser via import.meta.env) ──────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Server-side only (Vercel serverless functions — never exposed to browser) ─
ELEVENLABS_API_KEY=sk_...          # api/tts.js — live TTS proxy
OPENAI_API_KEY=sk-...              # api/chat.js, api/test.js — AI tutor
SUPABASE_URL=https://your-project.supabase.co   # api/waitlist.js
SUPABASE_SERVICE_KEY=your_service_role_key       # api/waitlist.js (elevated perms)

# ── Notes ─────────────────────────────────────────────────────────────────────
# Copy this file to .env.local for local development.
# NEVER commit .env or .env.local — both are in .gitignore.
# On Vercel: Project Settings -> Environment Variables.
# VITE_* vars are safe (public Supabase anon key is designed to be public).
